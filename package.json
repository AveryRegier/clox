{
  "name": "clox",
  "version": "0.2.6",
  "description": "A simple contextual logger that writes JSON to the console.",
  "main": "dist/index.js",
  "exports": {
    "import": "./dist/index.js",
    "require": "./dist/index.js"
  },
  "scripts": {
    "build": "tsc && node scripts/copy-package.js",
    "test": "vitest",
    "prepare": "npm run build",
    "pack:release": "npm pack --pack-destination release-artifacts",
    "release": "release-it --ci --no-github.release",
    "release:dry": "release-it --dry-run --ci --no-github.release",
    "clean": "rimraf dist coverage",
    "coverage": "vitest --run --coverage"
  },
  "keywords": [
    "logger",
    "context",
    "json",
    "console"
  ],
  "author": "Avery Regier <avery.regier@gmail.com> (https://github.com/AveryRegier)",
  "license": "Apache-2.0",
  "types": "dist/index.d.ts",
  "files": [
    "dist"
  ],
  "private": false,
  "devDependencies": {
    "@release-it/conventional-changelog": "^10.0.1",
    "@types/node": "^24.5.2",
    "@vitest/coverage-v8": "^3.2.4",
    "chance": "^1.1.13",
    "release-it": "^19.0.5",
    "rimraf": "^6.0.1",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "uuidv7": "^1.0.2"
  },
  "release-it": {
    "git": {
      "requireCleanWorkingDir": true,
      "commitMessage": "chore(release): v${version}",
      "tagName": "v${version}",
      "push": true
    },
    "github": {
      "release": false
    },
    "npm": {
      "publish": false
    },
    "plugins": {
      "@release-it/conventional-changelog": {
        "preset": "angular"
      }
    }
  }
}
